## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Ignore Visual Studio Code settings folder
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Collaboration directories
.builds

# Redgate SQL Tools
# Redgate SQL Compare:
SqlCompare.LastUsedState

# SQL Data Compare
SqlDataCompare.LastUsedState

# Redgate SQL Prompt
SqlPrompt.Metadata.xml

# Item bundle temp folder
_Chutzpah*

# Visual Studio 2012/2013/2015/2017/2019/2022 Project Packages
node_modules/
/packages/
# Libs
/lib/
# User-specific project settings
*.csproj.user
*.sqlproj.user
*.config.user
*.pubxml.user

# Others
.env
appsettings.Local.json
secrets.json
*.Backup.tmp

# Ignore unnecessary and irrelevant files
nothing

# Ignore all obj and bin folders in all projects
SweetMeet.Data/obj/
SweetMeet.Infrastructure/obj/
SweetMeet.API/obj/
SweetMeet.Domain/obj/
SweetMeet.Data/bin/
SweetMeet.Infrastructure/bin/
SweetMeet.API/bin/
SweetMeet.Domain/bin/

# Ignore migration snapshots except .cs files
SweetMeet.Data/Migrations/*
!SweetMeet.Data/Migrations/*.cs
/SweetMeet.Client/ssl
